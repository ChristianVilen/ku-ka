---
interface Props {
	title?: string;
}
const { title = "Ku-Ka — Screenshot. Annotate. Done." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A lightweight macOS app that replaces Shift+Cmd+4 with a better screenshot experience. Select, capture, annotate — all in one step." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-surface text-gray-200 font-sans antialiased overflow-x-hidden">
    <slot />
    <script>
      import '../scripts/animations.ts';
    </script>
  </body>
</html>
